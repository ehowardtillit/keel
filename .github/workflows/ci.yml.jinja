name: CI

on:
  push:
    branches: [main, master, develop]
  pull_request:
    branches: [main, master, develop]

concurrency:
  group: {% raw %}ci-${{ github.ref }}{% endraw %}
  cancel-in-progress: true

permissions:
  contents: read

jobs:
  context-staleness:
    name: Context File Freshness
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
        with:
          fetch-depth: 0
      - name: Check context file freshness
        run: |
          for file in .github/context/*.md; do
            if [ -f "$file" ]; then
              LAST_MODIFIED=$(git log -1 --format="%ci" -- "$file" 2>/dev/null | cut -d' ' -f1)
              if [ -n "$LAST_MODIFIED" ]; then
                DAYS_AGO=$(( ($(date +%s) - $(date -d "$LAST_MODIFIED" +%s)) / 86400 ))
                if [ "$DAYS_AGO" -gt 30 ]; then
                  echo "⚠️  STALE ($DAYS_AGO days): $file"
                else
                  echo "✅ Fresh ($DAYS_AGO days): $file"
                fi
              fi
            fi
          done

{% if lang_python %}
  lint-python:
    name: Lint (Python)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5.6.0
        with:
          python-version: '{{ python_version }}'
      - uses: actions/cache@5a3ec84eff668545956fd18022155c47e93e2684 # v4.2.3
        with:
          path: ~/.cache/pip
          key: {% raw %}pip-${{ hashFiles('**/requirements*.txt') }}{% endraw %}
      - run: pip install ruff==0.15.6
      - name: Ruff lint
        run: ruff check {{ source_dirs }} --ignore E501,F401 --exclude "*/venv/*,*/.venv/*"

  security-scan-python:
    name: Security Scan (Python)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5.6.0
        with:
          python-version: '{{ python_version }}'
      - uses: actions/cache@5a3ec84eff668545956fd18022155c47e93e2684 # v4.2.3
        with:
          path: ~/.cache/pip
          key: {% raw %}pip-${{ hashFiles('**/requirements*.txt') }}{% endraw %}
      - run: pip install bandit==1.9.4
      - name: Bandit scan
        run: bandit -r {{ source_dirs }} -ll --skip B101 -f txt

  test-python:
    name: Test (Python)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5.6.0
        with:
          python-version: '{{ python_version }}'
      - uses: actions/cache@5a3ec84eff668545956fd18022155c47e93e2684 # v4.2.3
        with:
          path: ~/.cache/pip
          key: {% raw %}pip-${{ hashFiles('**/requirements*.txt') }}{% endraw %}
      - name: Install dependencies
        run: |
          [ -f requirements.txt ] && pip install -r requirements.txt || true
          pip install pytest pytest-cov
      - name: Run tests
        run: |
          if [ -d tests ]; then
            pytest tests/ -v --tb=short --cov --cov-report=term-missing
          else
            echo "⚠️ No tests/ directory found -- skipping"
          fi

  dependency-audit-python:
    name: Dependency Audit (Python)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: actions/setup-python@a26af69be951a213d495a4c3e4e4022e16d87065 # v5.6.0
        with:
          python-version: '{{ python_version }}'
      - uses: actions/cache@5a3ec84eff668545956fd18022155c47e93e2684 # v4.2.3
        with:
          path: ~/.cache/pip
          key: {% raw %}pip-${{ hashFiles('**/requirements*.txt') }}{% endraw %}
      - run: pip install pip-audit
      - name: Audit dependencies
        run: '[ -f requirements.txt ] && pip-audit -r requirements.txt --desc || echo "No requirements.txt found -- skipping audit"'

  codeql-python:
    name: CodeQL (Python)
    runs-on: ubuntu-latest
    permissions:
      security-events: write
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: github/codeql-action/init@ff0a06e83cb2de871e5a09832bc6a81e7276941f # v3.28.18
        with:
          languages: python
      - uses: github/codeql-action/analyze@ff0a06e83cb2de871e5a09832bc6a81e7276941f # v3.28.18

{% endif %}
{% if lang_typescript %}
  lint-typescript:
    name: Lint (TypeScript)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: actions/setup-node@cdca7365b2dadb8aad0a33bc7601856ffabcc48e # v4.3.0
