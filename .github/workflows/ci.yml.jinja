{% if lang_elixir %}
  lint-elixir:
    name: Lint (Elixir)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: erlef/setup-beam@5304e04ea2b355f03681464e683d92e3b2f18451 # v1.18.2
        with:
          elixir-version: '{{ elixir_version }}'
          otp-version: '{{ otp_version }}'
      - uses: actions/cache@5a3ec84eff668545956fd18022155c47e93e2684 # v4.2.3
        with:
          path: |
            deps
            _build
          key: {% raw %}mix-${{ hashFiles('**/mix.lock') }}{% endraw %}
      - name: Install dependencies
        run: mix deps.get
      - name: Credo
        run: mix credo --strict

  test-elixir:
    name: Test (Elixir)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: erlef/setup-beam@5304e04ea2b355f03681464e683d92e3b2f18451 # v1.18.2
        with:
          elixir-version: '{{ elixir_version }}'
          otp-version: '{{ otp_version }}'
      - uses: actions/cache@5a3ec84eff668545956fd18022155c47e93e2684 # v4.2.3
        with:
          path: |
            deps
            _build
          key: {% raw %}mix-${{ hashFiles('**/mix.lock') }}{% endraw %}
      - name: Install dependencies
        run: mix deps.get
      - name: Mix test
        run: mix test

  security-scan-elixir:
    name: Security Scan (Elixir)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@11bd71901bbe5b1630ceea73d27597364c9af683 # v4.2.2
      - uses: erlef/setup-beam@5304e04ea2b355f03681464e683d92e3b2f18451 # v1.18.2
        with:
          elixir-version: '{{ elixir_version }}'
          otp-version: '{{ otp_version }}'
      - uses: actions/cache@5a3ec84eff668545956fd18022155c47e93e2684 # v4.2.3
        with:
          path: |
            deps
            _build
          key: {% raw %}mix-${{ hashFiles('**/mix.lock') }}{% endraw %}
      - name: Install dependencies
        run: mix deps.get
      - name: Sobelow
        run: mix sobelow --config
      - name: Install mix_audit
        run: mix archive.install hex mix_audit --force
      - name: Deps audit
        run: mix deps.audit

{% endif %}
