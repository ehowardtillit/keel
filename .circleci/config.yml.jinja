{% if ci_platform == "circleci" %}
# CircleCI -- generated by Batten
# Edit batten.yml, then run: ./batten regenerate

version: 2.1

jobs:
{% if lang_python %}
  lint-python:
    docker:
      - image: cimg/python:{{ python_version }}
    steps:
      - checkout
      - run:
          name: Install ruff
          command: pip install ruff==0.15.6
      - run:
          name: Ruff lint
          command: ruff check {{ source_dirs }} --ignore E501,F401 --exclude "*/venv/*,*/.venv/*"

  test-python:
    docker:
      - image: cimg/python:{{ python_version }}
    steps:
      - checkout
      - run:
          name: Install dependencies
          command: |
            [ -f requirements.txt ] && pip install -r requirements.txt || true
            pip install pytest pytest-cov
      - run:
          name: Run tests
          command: |
            if [ -d tests ]; then
              pytest tests/ -v --tb=short --cov --cov-report=term-missing
            else
              echo "No tests/ directory found -- skipping"
            fi

  security-scan-python:
    docker:
      - image: cimg/python:{{ python_version }}
    steps:
      - checkout
      - run:
          name: Install bandit
          command: pip install bandit==1.9.4
      - run:
          name: Bandit scan
          command: bandit -r {{ source_dirs }} -ll --skip B101 -f txt

{% endif %}
{% if lang_typescript %}
  lint-typescript:
    docker:
      - image: cimg/node:20.0
    steps:
      - checkout
      - run: npm ci
      - run:
          name: ESLint
          command: npx eslint . --max-warnings 0

  test-typescript:
    docker:
      - image: cimg/node:20.0
    steps:
      - checkout
      - run: npm ci
      - run:
          name: Vitest
          command: npx vitest run

{% endif %}
{% if lang_go %}
  lint-go:
    docker:
      - image: cimg/go:1.23
    steps:
      - checkout
      - run:
          name: Install golangci-lint
          command: go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest
      - run:
          name: Lint
          command: golangci-lint run

  test-go:
    docker:
      - image: cimg/go:1.23
    steps:
      - checkout
      - run:
          name: Go test
          command: go test ./...

{% endif %}
{% if lang_rust %}
  lint-rust:
    docker:
      - image: cimg/rust:1.79
    steps:
      - checkout
      - run:
          name: Clippy
          command: cargo clippy --all-targets -- -D warnings

  test-rust:
    docker:
      - image: cimg/rust:1.79
    steps:
      - checkout
      - run:
          name: Cargo test
          command: cargo test

{% endif %}
{% if lang_php %}
  lint-php:
    docker:
      - image: cimg/php:{{ php_version }}
    steps:
      - checkout
      - run: composer install --no-progress --no-suggest
      - run:
          name: PHP_CodeSniffer
          command: vendor/bin/phpcs --standard=PSR12 {{ source_dirs }}

  test-php:
    docker:
      - image: cimg/php:{{ php_version }}
    steps:
      - checkout
      - run: composer install --no-progress --no-suggest
      - run:
          name: PHPUnit
          command: vendor/bin/phpunit

{% endif %}
{% if lang_elixir %}
  lint-elixir:
    docker:
      - image: cimg/elixir:{{ elixir_version }}
    steps:
      - checkout
      - run: mix local.hex --force && mix deps.get
      - run:
          name: Credo
          command: mix credo --strict

  test-elixir:
    docker:
      - image: cimg/elixir:{{ elixir_version }}
    steps:
      - checkout
      - run: mix local.hex --force && mix deps.get
      - run:
          name: Mix test
          command: mix test

{% endif %}
{% if lang_java %}
  lint-java:
    docker:
      - image: cimg/openjdk:{{ java_version }}.0
    steps:
      - checkout
      - run:
          name: Checkstyle
          command: mvn checkstyle:check -q

  test-java:
    docker:
      - image: cimg/openjdk:{{ java_version }}.0
    steps:
      - checkout
      - run:
          name: Maven test
          command: mvn test -q

{% endif %}
{% if lang_csharp %}
  lint-csharp:
    docker:
      - image: mcr.microsoft.com/dotnet/sdk:{{ dotnet_version }}
    steps:
      - checkout
      - run: dotnet restore
      - run:
          name: Format check
          command: dotnet format --verify-no-changes

  test-csharp:
    docker:
      - image: mcr.microsoft.com/dotnet/sdk:{{ dotnet_version }}
    steps:
      - checkout
      - run: dotnet restore
      - run:
          name: Test
          command: dotnet test --no-restore --verbosity normal

{% endif %}
{% if lang_ruby %}
  lint-ruby:
    docker:
      - image: cimg/ruby:{{ ruby_version }}
    steps:
      - checkout
      - run: bundle install --quiet
      - run:
          name: RuboCop
          command: bundle exec rubocop

  test-ruby:
    docker:
      - image: cimg/ruby:{{ ruby_version }}
    steps:
      - checkout
      - run: bundle install --quiet
      - run:
          name: RSpec
          command: bundle exec rspec

{% endif %}

workflows:
  ci:
    jobs:
{% if lang_python %}
      - lint-python
      - test-python
      - security-scan-python
{% endif %}
{% if lang_typescript %}
      - lint-typescript
      - test-typescript
{% endif %}
{% if lang_go %}
      - lint-go
      - test-go
{% endif %}
{% if lang_rust %}
      - lint-rust
      - test-rust
{% endif %}
{% if lang_php %}
      - lint-php
      - test-php
{% endif %}
{% if lang_elixir %}
      - lint-elixir
      - test-elixir
{% endif %}
{% if lang_java %}
      - lint-java
      - test-java
{% endif %}
{% if lang_csharp %}
      - lint-csharp
      - test-csharp
{% endif %}
{% if lang_ruby %}
      - lint-ruby
      - test-ruby
{% endif %}
{% endif %}
