#!/usr/bin/env bash
# Batten Bootstrap — generated by Copier (one-shot project setup)
set -euo pipefail

BOLD=$'\033[1m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
RED=$'\033[0;31m'
NC=$'\033[0m'

info() { printf '%b%s%b\n' "${BOLD}" "$1" "${NC}"; }
ok() { printf '%b✅ %s%b\n' "${GREEN}" "$1" "${NC}"; }
warn() { printf '%b⚠️  %s%b\n' "${YELLOW}" "$1" "${NC}"; }
fail() { printf '%b❌ %s%b\n' "${RED}" "$1" "${NC}"; exit 1; }

info "Batten Bootstrap"
echo ""

# --- Repository -------------------------------------------------------------

if [[ ! -d .git ]]; then
  fail "Not a git repository. Run this script from the project root (where .git exists)."
fi
ok "Git repository found"

# --- Tooling paths (non-Python projects may use ~/.local/bin) ---------------

export PATH="${HOME}/.local/bin:${PATH}"

ensure_pre_commit_and_secrets_tools() {
  if command -v pre-commit &>/dev/null && command -v detect-secrets &>/dev/null; then
    return 0
  fi
  if command -v python3 &>/dev/null; then
    warn "Installing pre-commit and detect-secrets (user site-packages)..."
    python3 -m pip install --user pre-commit detect-secrets >/dev/null 2>&1 || true
  fi
}

{% if lang_python %}
# --- Python -----------------------------------------------------------------

if ! command -v python3 &>/dev/null; then
  fail "python3 not found. Install Python or disable lang_python in Batten."
fi

if [[ ! -d .venv ]]; then
  info "Creating Python virtual environment (.venv)..."
  python3 -m venv .venv
fi
# shellcheck source=/dev/null
source .venv/bin/activate

ok "Python venv active ({{ python_version }} toolchain — align local pyenv/CI as needed)"

info "Installing pre-commit and Python dev tools..."
python -m pip install -U pip >/dev/null
python -m pip install pre-commit ruff bandit pytest pytest-cov pip-audit detect-secrets >/dev/null
ok "Installed: pre-commit, ruff, bandit, pytest, pytest-cov, pip-audit, detect-secrets"

{% else %}
ensure_pre_commit_and_secrets_tools
{% endif %}

{% if lang_typescript %}
# --- TypeScript / Node ------------------------------------------------------

if ! command -v node &>/dev/null; then
  fail "node not found. Install Node.js or disable lang_typescript in Batten."
fi

if command -v npm &>/dev/null; then
  ok "Found npm"
elif command -v bun &>/dev/null; then
  ok "Found bun"
else
  warn "Neither npm nor bun found on PATH — install one for JS tooling."
fi
info "Install eslint and vitest in your package.json (Batten expects them when TypeScript is enabled)."
echo ""

{% endif %}

{% if lang_go %}
# --- Go ---------------------------------------------------------------------

if ! command -v go &>/dev/null; then
  fail "go not found. Install Go or disable lang_go in Batten."
fi
ok "Go toolchain found"
info "Install golangci-lint: go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest"
echo ""

{% endif %}

{% if lang_rust %}
# --- Rust -------------------------------------------------------------------

if ! command -v rustc &>/dev/null || ! command -v cargo &>/dev/null; then
  fail "rustc and cargo are required. Install Rust (rustup) or disable lang_rust in Batten."
fi
ok "Rust toolchain found"
info "Run: rustup component add clippy"
echo ""

{% endif %}

{% if lang_php %}
# --- PHP --------------------------------------------------------------------

if ! command -v php &>/dev/null; then
  fail "php not found. Install PHP or disable lang_php in Batten."
fi
ok "PHP found ($(php -v | head -1 | awk '{print $2}'))"

if ! command -v composer &>/dev/null; then
  warn "Composer not found. Install from https://getcomposer.org/"
else
  ok "Composer found"
  if [[ -f composer.json ]]; then
    info "Installing PHP dependencies..."
    composer install --no-progress --no-suggest 2>/dev/null || warn "composer install had issues"
  fi
fi
info "Batten expects phpcs and phpunit available via Composer (require-dev)."
echo ""

{% endif %}

{% if lang_elixir %}
# --- Elixir / Erlang --------------------------------------------------------

if ! command -v elixir &>/dev/null; then
  fail "elixir not found. Install Elixir (https://elixir-lang.org/install.html) or disable lang_elixir in Batten."
fi
ok "Elixir found ($(elixir --version | tail -1 | awk '{print $2}'))"

if ! command -v mix &>/dev/null; then
  fail "mix not found. Install Elixir properly."
fi

info "Fetching Elixir dependencies..."
mix local.hex --force >/dev/null 2>&1
mix local.rebar --force >/dev/null 2>&1
if [[ -f mix.exs ]]; then
  mix deps.get >/dev/null 2>&1 || warn "mix deps.get had issues"
fi
info "Batten expects credo and sobelow as dev deps in mix.exs."
echo ""

{% endif %}

{% if lang_csharp %}
# --- C# / .NET --------------------------------------------------------------

if ! command -v dotnet &>/dev/null; then
  fail "dotnet not found. Install .NET SDK or disable lang_csharp in Batten."
fi
ok ".NET SDK found ($(dotnet --version))"
info "Batten expects dotnet format and dotnet test to work out of the box."
echo ""

{% endif %}

{% if lang_ruby %}
# --- Ruby -------------------------------------------------------------------

if ! command -v ruby &>/dev/null; then
  fail "ruby not found. Install Ruby or disable lang_ruby in Batten."
fi
ok "Ruby found ($(ruby --version | awk '{print $2}'))"

if ! command -v bundle &>/dev/null; then
  warn "Bundler not found. Install with: gem install bundler"
else
  ok "Bundler found"
  if [[ -f Gemfile ]]; then
    info "Installing Ruby dependencies..."
    bundle install --quiet 2>/dev/null || warn "bundle install had issues"
  fi
fi
info "Batten expects rubocop and rspec available via Bundler."
echo ""

{% endif %}

# --- Pre-commit hooks -------------------------------------------------------

if ! command -v pre-commit &>/dev/null; then
  warn "pre-commit not on PATH — install it (e.g. pip install --user pre-commit) and re-run bootstrap."
else
  if pre-commit install; then
    ok "pre-commit hooks installed"
  else
    warn "pre-commit install reported an error — fix and run pre-commit install again"
  fi
fi

# --- Secrets baseline -------------------------------------------------------

if command -v detect-secrets &>/dev/null; then
  if [[ ! -f .secrets.baseline ]]; then
    info "Generating .secrets.baseline..."
    detect-secrets scan \
      --exclude-files '\.venv|venv|__pycache__|node_modules|\.git|docs/book' \
      > .secrets.baseline || true
    ok "Secrets baseline created — review and commit .secrets.baseline"
  else
    info "Auditing against existing .secrets.baseline..."
    detect-secrets scan --baseline .secrets.baseline &>/dev/null || true  # new findings are OK during bootstrap
    ok "Secrets baseline present (.secrets.baseline) — audit step completed"
  fi
else
  warn "detect-secrets not found — skipping baseline (install via pip / your Python env)."
fi

{% if mempalace_enabled %}
# --- MemPalace (engineering context -- not a project runtime dependency) -----

if command -v python3 &>/dev/null; then
  {% if lang_python %}
  # shellcheck source=/dev/null
  [[ -f .venv/bin/activate ]] && source .venv/bin/activate
  python -m pip install mempalace >/dev/null 2>&1 || warn "Could not pip install mempalace into .venv"
  {% else %}
  python3 -m pip install --user mempalace >/dev/null 2>&1 || warn "Could not pip install mempalace (user site)"
  {% endif %}
  hash -r 2>/dev/null || true
fi

if [[ ! -d "${HOME}/.mempalace" ]]; then
  if command -v mempalace &>/dev/null; then
    mempalace init || warn "mempalace init failed"
  else
    warn "mempalace CLI not found after install attempt"
  fi
else
  ok "MemPalace config directory exists (~/.mempalace)"
fi

BATTEN_WING="$(printf '%s' "{{ project_name }}" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9_-]/-/g' | sed 's/-\{2,\}/-/g; s/^-//; s/-$//')"
if [[ -z "${BATTEN_WING}" ]]; then
  BATTEN_WING="batten-project"
fi

if command -v mempalace &>/dev/null; then
  mempalace mine . --wing "${BATTEN_WING}" || warn "mempalace mine completed with warnings"
  ok "MemPalace configured — MCP server available"
else
  warn "Skipping mempalace mine (mempalace not on PATH)"
fi
echo ""

{% endif %}

{% if gstack_enabled %}
# --- gstack -----------------------------------------------------------------

GSTACK_DIR="${HOME}/.claude/skills/gstack"
if [[ -d "${GSTACK_DIR}" ]]; then
  ok "gstack found at ${GSTACK_DIR}"
else
  warn "gstack not installed."
  info "Install gstack: git clone --single-branch --depth 1 https://github.com/garrytan/gstack.git ~/.claude/skills/gstack && cd ~/.claude/skills/gstack && ./setup"
fi
echo ""

{% endif %}

{% if runtime_enforcement == "caliper" %}
info "Run 'npx caliper init' to compile conventions into stop hooks"
echo ""
{% elif runtime_enforcement == "agentsteer" %}
info "Run 'npx agentsteer' to install runtime guardrails"
echo ""
{% endif %}

{% if merge_gate == "agent-guardrails" %}
info "Configure agent-guardrails MCP server for scope validation"
echo ""
{% elif merge_gate == "roborev" %}
info "Run 'roborev init' to install post-commit review hooks"
echo ""
{% endif %}

{% if codeguard_enabled %}
info "Download CodeGuard rules: see https://project-codeguard.org/getting-started/"
echo ""
{% endif %}

# --- Warm up pre-commit -----------------------------------------------------

if command -v pre-commit &>/dev/null; then
  info "Running pre-commit on all files (first run may be slow)..."
  pre-commit run --all-files &>/dev/null || true
  ok "pre-commit dry run finished (warnings ignored)"
fi

# --- Customization checklist ------------------------------------------------

info "Customization checklist"
echo "  • Agent instructions: CLAUDE.md / AGENTS.md / .cursor/rules/batten.mdc / .github/copilot-instructions.md"
echo "  • Context files: .github/context/MODULE_MAP.md, .github/context/CHANGELOG_RECENT.md — run ./batten context refresh after changes"
echo "  • Source dirs for tooling: {{ source_dirs }}"
{% if dependency_updates == "dependabot" %}
echo "  • Dependency updates: Dependabot — tune .github/dependabot.yml"
{% elif dependency_updates == "renovate" %}
echo "  • Dependency updates: Renovate — tune renovate.json / .github/renovate.json"
{% else %}
echo "  • Dependency updates: none selected — configure manually if needed"
{% endif %}
echo ""

ok "Batten bootstrap complete — happy shipping!"
