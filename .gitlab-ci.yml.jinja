{% if ci_platform == "gitlab" %}
# GitLab CI -- generated by Batten
# Edit batten.yml, then run: ./batten regenerate

stages:
  - lint
  - test
  - security

{% if lang_python %}
lint-python:
  stage: lint
  image: python:{{ python_version }}
  script:
    - pip install ruff==0.15.6
    - ruff check {{ source_dirs }} --ignore E501,F401 --exclude "*/venv/*,*/.venv/*"

test-python:
  stage: test
  image: python:{{ python_version }}
  script:
    - "[ -f requirements.txt ] && pip install -r requirements.txt || true"
    - pip install pytest pytest-cov
    - |
      if [ -d tests ]; then
        pytest tests/ -v --tb=short --cov --cov-report=term-missing
      else
        echo "No tests/ directory found -- skipping"
      fi

security-scan-python:
  stage: security
  image: python:{{ python_version }}
  script:
    - pip install bandit==1.9.4
    - bandit -r {{ source_dirs }} -ll --skip B101 -f txt
  allow_failure: true

{% endif %}
{% if lang_typescript %}
lint-typescript:
  stage: lint
  image: node:20
  script:
    - npm ci
    - npx eslint . --max-warnings 0

test-typescript:
  stage: test
  image: node:20
  script:
    - npm ci
    - npx vitest run

{% endif %}
{% if lang_go %}
lint-go:
  stage: lint
  image: golangci/golangci-lint:latest
  script:
    - golangci-lint run

test-go:
  stage: test
  image: golang:1.23
  script:
    - go test ./...

{% endif %}
{% if lang_rust %}
lint-rust:
  stage: lint
  image: rust:latest
  script:
    - rustup component add clippy
    - cargo clippy --all-targets -- -D warnings

test-rust:
  stage: test
  image: rust:latest
  script:
    - cargo test

{% endif %}
{% if lang_php %}
lint-php:
  stage: lint
  image: php:{{ php_version }}
  script:
    - composer install --no-progress --no-suggest
    - vendor/bin/phpcs --standard=PSR12 {{ source_dirs }}

test-php:
  stage: test
  image: php:{{ php_version }}
  script:
    - composer install --no-progress --no-suggest
    - vendor/bin/phpunit

{% endif %}
{% if lang_elixir %}
lint-elixir:
  stage: lint
  image: elixir:{{ elixir_version }}
  script:
    - mix local.hex --force
    - mix local.rebar --force
    - mix deps.get
    - mix credo --strict

test-elixir:
  stage: test
  image: elixir:{{ elixir_version }}
  script:
    - mix local.hex --force
    - mix local.rebar --force
    - mix deps.get
    - mix test

{% endif %}
{% if lang_java %}
lint-java:
  stage: lint
  image: maven:3-eclipse-temurin-{{ java_version }}
  script:
    - mvn checkstyle:check -q

test-java:
  stage: test
  image: maven:3-eclipse-temurin-{{ java_version }}
  script:
    - mvn test -q

security-scan-java:
  stage: security
  image: maven:3-eclipse-temurin-{{ java_version }}
  script:
    - mvn org.owasp:dependency-check-maven:check -q
  allow_failure: true

{% endif %}
{% if lang_csharp %}
lint-csharp:
  stage: lint
  image: mcr.microsoft.com/dotnet/sdk:{{ dotnet_version }}
  script:
    - dotnet restore
    - dotnet format --verify-no-changes

test-csharp:
  stage: test
  image: mcr.microsoft.com/dotnet/sdk:{{ dotnet_version }}
  script:
    - dotnet restore
    - dotnet test --no-restore --verbosity normal

security-scan-csharp:
  stage: security
  image: mcr.microsoft.com/dotnet/sdk:{{ dotnet_version }}
  script:
    - dotnet restore
    - dotnet list package --vulnerable --include-transitive
  allow_failure: true

{% endif %}
{% if lang_ruby %}
lint-ruby:
  stage: lint
  image: ruby:{{ ruby_version }}
  script:
    - bundle install --quiet
    - bundle exec rubocop

test-ruby:
  stage: test
  image: ruby:{{ ruby_version }}
  script:
    - bundle install --quiet
    - bundle exec rspec

security-scan-ruby:
  stage: security
  image: ruby:{{ ruby_version }}
  script:
    - bundle install --quiet
    - bundle exec bundler-audit check --update
  allow_failure: true

{% endif %}
{% endif %}
