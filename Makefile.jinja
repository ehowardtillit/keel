# ⚓ KEEL -- Project Makefile
# Customize: add your project-specific targets below the KEEL section

.PHONY: help bootstrap lint test security-scan secrets-baseline context-refresh docs-check

help: ## Show this help
	@grep -E '^[a-zA-Z_-]+:.*?## .*$$' $(MAKEFILE_LIST) | awk 'BEGIN {FS = ":.*?## "}; {printf "  \033[36m%-20s\033[0m %s\n", $$1, $$2}'

# --- Bootstrap ---

bootstrap: ## Run first-time project setup
	@./bootstrap.sh

# --- Quality ---

lint: ## Lint all Python files with ruff
	ruff check {{ source_dirs }} --ignore E501,F401 --exclude "*/venv/*,*/.venv/*"

format: ## Auto-format with ruff
	ruff format .

test: ## Run tests with pytest
	pytest tests/ -v --tb=short || test $$? -eq 5

test-coverage: ## Run tests with coverage report
	pytest tests/ -v --tb=short --cov --cov-report=term-missing

security-scan: ## Run bandit security scan
	bandit -r {{ source_dirs }} -ll --skip B101 -f txt

# --- Secrets ---

secrets-baseline: ## Regenerate .secrets.baseline
	# docs/book is excluded in case project uses mdBook for documentation output
	detect-secrets scan \
		--exclude-files '\.venv|venv|__pycache__|node_modules|\.git|docs/book' \
		> .secrets.baseline
	@echo "✅ Secrets baseline regenerated -- review and commit"

secrets-audit: ## Check for new secrets not in baseline
	# docs/book is excluded in case project uses mdBook for documentation output
	detect-secrets scan \
		--exclude-files '\.venv|venv|__pycache__|node_modules|\.git|docs/book' \
		--baseline .secrets.baseline

# --- Context Management ---

context-refresh: ## Regenerate .github/context/ files from code and git
	@echo "# Module Map" > .github/context/MODULE_MAP.md
	@echo "" >> .github/context/MODULE_MAP.md
	@echo "<!-- Auto-generated by \`make context-refresh\` -- do not edit manually -->" >> .github/context/MODULE_MAP.md
	@echo "" >> .github/context/MODULE_MAP.md
	@# Customize: change the find path to your source directories
	@for dir in $$(find . -maxdepth 2 -name "*.py" 2>/dev/null | sed 's|/[^/]*$$||' | sort -u | grep -v -E '\.venv|venv|__pycache__|\.git' | head -30); do \
		count=$$(find "$$dir" -maxdepth 1 -name "*.py" | wc -l); \
		echo "| \`$$dir\` | $$count files |" >> .github/context/MODULE_MAP.md; \
	done
	@echo "" >> .github/context/MODULE_MAP.md
	@echo "# Recent Changes" > .github/context/CHANGELOG_RECENT.md
	@echo "" >> .github/context/CHANGELOG_RECENT.md
	@echo "<!-- Auto-generated by \`make context-refresh\` -- do not edit manually -->" >> .github/context/CHANGELOG_RECENT.md
	@echo "" >> .github/context/CHANGELOG_RECENT.md
	@git log --oneline -50 >> .github/context/CHANGELOG_RECENT.md 2>/dev/null || echo "No git history yet" >> .github/context/CHANGELOG_RECENT.md
	@echo "" >> .github/context/CHANGELOG_RECENT.md
	@# Append recent plans and implementations as context
	@echo "## Recent Plans" >> .github/context/CHANGELOG_RECENT.md
	@echo "" >> .github/context/CHANGELOG_RECENT.md
	@for f in $$(ls -t docs/plans/*.md 2>/dev/null | grep -v template | grep -v README | head -5); do \
		title=$$(head -1 "$$f" | sed 's/^# //'); \
		echo "- [\`$$f\`] $$title" >> .github/context/CHANGELOG_RECENT.md; \
	done
	@echo "" >> .github/context/CHANGELOG_RECENT.md
	@echo "## Recent Implementations" >> .github/context/CHANGELOG_RECENT.md
	@echo "" >> .github/context/CHANGELOG_RECENT.md
	@for f in $$(ls -t docs/implementations/*.md 2>/dev/null | grep -v template | grep -v README | head -5); do \
		title=$$(head -1 "$$f" | sed 's/^# //'); \
		echo "- [\`$$f\`] $$title" >> .github/context/CHANGELOG_RECENT.md; \
	done
	@echo "✅ Context files refreshed"

# --- Docs ---

docs-check: ## Verify documentation build (if using mdBook)
	@command -v mdbook >/dev/null 2>&1 && mdbook build docs/ || echo "mdbook not installed -- skipping"

# --- Pre-commit ---

hooks-install: ## Install pre-commit hooks
	pre-commit install

hooks-run: ## Run all pre-commit hooks on all files
	pre-commit run --all-files

