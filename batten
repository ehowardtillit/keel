# -- YAML loading -------------------------------------------------------------

def _strip_comment(line):
    """Strip comments from a YAML line while respecting quoted strings."""
    in_single = in_double = False
    for i, c in enumerate(line):
        if c == '"' and not in_single:
            in_double = not in_double
        elif c == "'" and not in_double:
            in_single = not in_single
        elif c == '#' and not in_single and not in_double:
            return line[:i].rstrip()
    return line.rstrip()


def _parse_yaml_basic(text):
    """Minimal YAML-subset parser for when PyYAML is unavailable."""
    root = {}
    stack = [(root, -1)]
    for raw in text.splitlines():
        s = _strip_comment(raw)
        if not s or s.startswith("#"):
            continue
        indent, kv = len(raw) - len(raw.lstrip()), s.strip()
        while len(stack) > 1 and indent <= stack[-1][1]:
            stack.pop()
        if ":" in kv:
            key, _, val = kv.partition(":")
            key, val = key.strip(), val.strip().strip('"').strip("'")
            if val == "":
                child = {}
                stack[-1][0][key] = child
                stack.append((child, indent))
            elif val == "[]":
                stack[-1][0][key] = []
            elif val.startswith("["):
                stack[-1][0][key] = [
                    i.strip().strip('"').strip("'")
                    for i in val.strip("[]").split(",") if i.strip()
                ]
            elif val.lower() in ("true", "false"):
                stack[-1][0][key] = val.lower() == "true"
            else:
                try:
                    stack[-1][0][key] = int(val)
                except ValueError:
                    stack[-1][0][key] = val
        elif kv.startswith("- "):
            item = kv[2:].strip().strip('"').strip("'")
            parent = stack[-1][0]
            if isinstance(parent, dict):
                lk = list(parent.keys())[-1]
                if not isinstance(parent[lk], list):
                    parent[lk] = []
                parent[lk].append(item)
    return root


def load_batten():
    if not os.path.exists(BATTEN_FILE):
        print(f"Error: {BATTEN_FILE} not found in current directory.", file=sys.stderr)
        sys.exit(1)
    from pathlib import Path
    text = Path(BATTEN_FILE).read_text()
    return yaml.safe_load(text) if yaml else _parse_yaml_basic(text)


def _get(data, dotpath, default=None):
    node = data
    for k in dotpath.split("."):
        if not isinstance(node, dict) or k not in node:
            return default
        node = node[k]
    return node


def _enabled_langs(data):
    return [l for l in LANGUAGES if _get(data, f"languages.{l}.enabled")]


def _source_dirs(data):
    return _get(data, "project.source_dirs", "src/")


def _project_slug(data):
    name = _get(data, "project.name", "project")
    return re.sub(r'[^a-z0-9_-]', '-', name.lower()).strip('-')


def build_copier_flags(data):
    flags = []
    for dotpath, copier_key, transform in FIELD_MAP:
        val = _get(data, dotpath)
        if val is None:
            continue
        val = transform(val) if transform else val
        if isinstance(val, bool):
            val = str(val).lower()
        flags += ["-d", f"{copier_key}={val}"]
    return flags


def _run(cmd, check=True, capture=False, timeout=300, **kwargs):
    """Run a command, return CompletedProcess."""
    if isinstance(cmd, str):
        kwargs.setdefault("shell", True)
    try:
        result = subprocess.run(cmd, capture_output=capture, text=True, timeout=timeout, **kwargs)
    except subprocess.TimeoutExpired:
        cmd_str = cmd if isinstance(cmd, str) else " ".join(cmd)
        print(f"Command timed out after {timeout}s: {cmd_str}", file=sys.stderr)
        sys.exit(1)
    if check and result.returncode != 0:
        cmd_str = cmd if isinstance(cmd, str) else " ".join(cmd)
        print(f"Command failed (exit {result.returncode}): {cmd_str}", file=sys.stderr)
        sys.exit(result.returncode)
    return result


def _run_quiet(cmd, **kwargs):
    return _run(cmd, check=False, capture=True, **kwargs)


def _has_cmd(name):
    return shutil.which(name) is not None


