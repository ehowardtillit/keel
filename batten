def cmd_lint(args):
    data = load_batten()
    cmds = _lint_commands(data)
    if not cmds:
        print("No languages enabled for linting.")
        return
    lang_filter = args.lang if hasattr(args, "lang") and args.lang else None
    extra = args.passthrough if hasattr(args, "passthrough") and args.passthrough else []
    failed = []
    for label, cmd in cmds:
        if lang_filter and lang_filter.lower() not in label.lower():
            continue
        if extra:
            cmd = cmd + extra
        print(f"  Linting: {label}")
        r = _run(cmd, check=False)
        if r.returncode != 0:
            failed.append(label)
    if failed:
        _err(f"Lint failures: {', '.join(failed)}")
        sys.exit(1)
    _ok("All linters passed.")


