def cmd_doctor(_args):
    data = load_batten()
    _info("Doctor -- checking required tools")
    print("\u2500" * 40)

    ok_count = 0
    miss_count = 0

    def _check(name, desc):
        nonlocal ok_count, miss_count
        if _has_cmd(name):
            _ok(f"  {name}: found")
            ok_count += 1
        else:
            _warn(f"  {name}: NOT FOUND -- {desc}")
            miss_count += 1

    print("\n  Global tools:")
    for name, desc in GLOBAL_TOOLS:
        _check(name, desc)

    if _get(data, "stack.engineering_memory.mempalace"):
        _check("mempalace", "Engineering memory (pip install mempalace)")

    langs = _enabled_langs(data)
    for lang in langs:
        label = {"csharp": "C#/.NET", "typescript": "TypeScript",
                 "elixir": "Elixir/Erlang"}.get(lang, lang.capitalize())
        print(f"\n  {label} tools:")
        for name, desc in TOOL_CHECKS.get(lang, []):
            _check(name, desc)

    print(f"\n{'─' * 40}")
    if miss_count == 0:
        _ok(f"All {ok_count} tools found. Environment is ready.")
    else:
        _warn(f"{ok_count} found, {miss_count} missing. Install missing tools for full functionality.")


