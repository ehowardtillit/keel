def cmd_eject(_args):
    load_batten()
    _info("Ejecting from Batten...")
    for f in ["batten.yml", ".copier-answers.yml"]:
        if os.path.exists(f):
            os.remove(f)
            print(f"  Removed {f}")
    print("  Generated files (CI, hooks, agent instructions) are yours to keep.")
    print("  Remove ./batten when ready.")
    print("\nEjection complete. Your project is now standalone.")


# -- Entry point ---------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(
        prog="batten",
        description="batten -- Engineering Stack CLI\n\nReads batten.yml and manages infrastructure.",
        epilog=textwrap.dedent("""\
            examples:
              ./batten doctor                 Check tool availability
              ./batten install                Full setup
              ./batten lint --lang python     Lint only Python
              ./batten lint -- --fix          Pass --fix to the underlying linter
              ./batten context refresh        Regenerate context files
              ./batten memory search <query>  Search MemPalace
              ./batten validate --check-drift Check for config drift
              ./batten eject                  Remove batten config, keep generated files
        """),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("-V", "--version", action="version",
                        version=f"batten {_version()}")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("init", help="Interactive setup: create batten.yml from scratch")
    sub.add_parser("install", help="Full setup: bootstrap + methodology + hooks + tools")
    sub.add_parser("bootstrap", help="Run bootstrap.sh only (language toolchains)")
    sub.add_parser("status", help="Show batten.yml configuration summary")
    sub.add_parser("doctor", help="Check that required tools are installed")

    p_validate = sub.add_parser("validate", help="Check batten.yml for errors")
    p_validate.add_argument("--check-drift", action="store_true",
                            help="Check if generated files match batten.yml")

    sub.add_parser("regenerate", help="Regenerate infrastructure from batten.yml")
    sub.add_parser("diff", help="Preview what regenerate would change")

    p_lint = sub.add_parser("lint", help="Run linters for enabled languages")
    p_lint.add_argument("--lang", help="Filter to specific language (e.g. python, go)")
    p_lint.add_argument("passthrough", nargs="*", help="Extra args after --")

    p_test = sub.add_parser("test", help="Run tests for enabled languages")
    p_test.add_argument("--lang", help="Filter to specific language")
    p_test.add_argument("passthrough", nargs="*", help="Extra args after --")

    sub.add_parser("format", help="Auto-format code")
    sub.add_parser("security-scan", help="Run security scanners")

    p_hooks = sub.add_parser("hooks", help="Manage pre-commit hooks")
    p_hooks.add_argument("action", nargs="?", default="run",
                         choices=["install", "run"], help="install or run")

    p_secrets = sub.add_parser("secrets", help="Manage secrets baseline")
    p_secrets.add_argument("action", nargs="?", default="audit",
                           choices=["baseline", "audit"])

    p_ctx = sub.add_parser("context", help="Manage AI context files")
    p_ctx.add_argument("action", nargs="?", default="refresh",
                       choices=["refresh", "live"])

    p_mem = sub.add_parser("memory", help="MemPalace operations")
    p_mem.add_argument("action", nargs="?", default="status",
                       choices=["status", "mine", "search"])
    p_mem.add_argument("query", nargs="?", default="", help="Search query")

    sub.add_parser("eject", help="Remove batten config, keep generated files")

    args = parser.parse_args()
    if not args.command:
        parser.print_help()
        sys.exit(0)

    dispatch = {
        "init": cmd_init,
        "install": cmd_install,
        "bootstrap": cmd_bootstrap,
        "status": cmd_status,
        "doctor": cmd_doctor,
        "validate": cmd_validate,
        "regenerate": cmd_regenerate,
        "diff": cmd_diff,
        "lint": cmd_lint,
        "test": cmd_test,
        "format": cmd_format,
        "security-scan": cmd_security_scan,
        "hooks": cmd_hooks,
        "secrets": cmd_secrets,
        "context": cmd_context,
        "memory": cmd_memory,
        "eject": cmd_eject,
    }
    dispatch[args.command](args)


if __name__ == "__main__":
    main()
