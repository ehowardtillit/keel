def cmd_status(_args):
    data = load_batten()
    lang_labels = {"csharp": "C#/.NET", "typescript": "TypeScript", "elixir": "Elixir/Erlang"}
    langs = []
    for lang in LANGUAGES:
        info = _get(data, f"languages.{lang}", {})
        if not info.get("enabled"):
            continue
        label = lang_labels.get(lang, lang.capitalize())
        ver = info.get("version")
        langs.append(f"{label} {ver}" if ver else label)

    agents = [lbl for key, lbl in AGENT_LABELS if _get(data, f"agents.{key}")]
    mtype = _get(data, "methodology.type", "batten")
    msource = _get(data, "methodology.source")
    mpath = _get(data, "methodology.path", ".methodology")
    mver = _get(data, "methodology.version")
    if mtype in ("keel", "batten"):
        mtype_display = "batten (S/A/B/C tiers)"
    elif msource:
        installed = os.path.isdir(mpath) if mpath else False
        src_short = msource.rsplit("/", 1)[-1].replace(".git", "")
        mtype_display = f"custom: {src_short}"
        if mver:
            mtype_display += f" @ {mver}"
        if not installed:
            mtype_display += " (not installed -- run ./batten install)"
    else:
        mtype_display = "custom"
    rt = _get(data, "stack.enforcement.runtime", "none")
    mg = _get(data, "stack.enforcement.merge_gate", "none")
    enforcement = [x for x in (rt, mg) if x != "none"]
    ci_jobs = _get(data, "ci_extra_jobs", [])
    ci_plat = _get(data, "ci.platform", "github")

    _info("Stack Status")
    print("\u2500" * 40)
    print(f"  Project:      {_get(data, 'project.name', '?')} (owner: {_get(data, 'project.owner', '?')})")
    print(f"  Methodology:  {mtype_display}")
    print(f"  Branching:    {_get(data, 'methodology.branching', '?')}")
    print(f"  Languages:    {', '.join(langs) if langs else 'none'}")
    print(f"  Agents:       {', '.join(agents) if agents else 'none'}")
    print(f"  CI Platform:  {ci_plat}")
    print(f"  Eng. Memory:  {'MemPalace (context/agents)' if _get(data, 'stack.engineering_memory.mempalace') else 'none'}")
    print(f"  Workflow:     {'gstack' if _get(data, 'stack.workflow.gstack') else 'none'}")
    print(f"  Enforcement:  {' / '.join(enforcement) if enforcement else 'none'}")
    print(f"  Security:     {'CodeGuard' if _get(data, 'stack.security.codeguard') else 'none'}")
    print(f"  Dependencies: {_get(data, 'stack.dependencies.updater', 'none')}")
    if ci_jobs:
        print(f"  CI Extensions: {len(ci_jobs)} custom job{'s' if len(ci_jobs) != 1 else ''}")


def cmd_validate(args):
    data = load_batten()
    errors, warnings = [], []
    if _get(data, "version") != 1:
        errors.append("'version' must be 1")
    if not _get(data, "project.name"):
        errors.append("'project.name' is required")
    if not _enabled_langs(data):
        errors.append("At least one language must be enabled")
    if (_get(data, "methodology.type") == "custom"
            and not _get(data, "methodology.skip_agent_instructions")):
        warnings.append(
            "methodology.type is 'custom' but skip_agent_instructions is false -- "
            "Batten agent instructions may conflict with your methodology")

    if hasattr(args, 'check_drift') and args.check_drift:
        print("  Checking for drift...")
        flags = build_copier_flags(data)
        cmd = ["copier", "update", "--trust", "--force", "--pretend"] + flags
        r = subprocess.run(cmd, capture_output=True, text=True)
        if "identical" not in r.stdout.lower() and r.stdout.strip():
            warnings.append("Generated files may be out of sync with batten.yml. Run ./batten regenerate.")

    for w in warnings:
        print(f"  Warning: {w}")
    if errors:
        for e in errors:
            print(f"  Error: {e}", file=sys.stderr)
        sys.exit(1)
    _ok("batten.yml is valid.")


def _write_ci_custom(jobs, ci_platform="github"):
    if not jobs:
        return
    if ci_platform == "github":
        _write_ci_custom_github(jobs)
    elif ci_platform == "gitlab":
        _write_ci_custom_gitlab(jobs)
    elif ci_platform == "circleci":
        _write_ci_custom_circleci(jobs)


def _sanitize_slug(name):
    return re.sub(r'[^a-z0-9-]', '-', name.lower()).strip('-')


def _yaml_block_scalar(text):
    """Format a command string as a YAML block scalar, handling multi-line."""
    lines = text.strip().splitlines()
    if len(lines) == 1:
        return lines[0]
    return "\n".join(lines)


def _write_ci_custom_github(jobs):
    os.makedirs(".github/workflows", exist_ok=True)
    doc = {
        "name": "CI Custom",
        "on": {"push": {"branches": ["main", "master"]}, "pull_request": None},
        "jobs": {},
    }
    for job in jobs:
        name = job.get("name", "custom")
        slug = _sanitize_slug(name)
        run_cmd = job.get("run", "echo 'no command specified'")
        doc["jobs"][slug] = {
            "name": name,
            "runs-on": "ubuntu-latest",
            "steps": [
                {"uses": "actions/checkout@v4"},
                {"name": name, "run": _yaml_block_scalar(run_cmd)},
            ],
        }
    path = os.path.join(".github", "workflows", "ci-custom.yml")
    _write_yaml_file(path, doc, header="# Auto-generated by batten regenerate -- do not edit manually.")


def _write_ci_custom_gitlab(jobs):
    doc = {}
    for job in jobs:
        name = job.get("name", "custom")
        slug = _sanitize_slug(name)
        run_cmd = job.get("run", "echo 'no command specified'")
        doc[slug] = {
            "stage": "test",
            "script": run_cmd.strip().splitlines(),
        }
    path = ".gitlab-ci-custom.yml"
    _write_yaml_file(path, doc, header="# Auto-generated by batten regenerate -- do not edit manually.")


def _write_ci_custom_circleci(jobs):
    os.makedirs(".circleci", exist_ok=True)
    job_defs = {}
    workflow_jobs = []
    for job in jobs:
        name = job.get("name", "custom")
        slug = _sanitize_slug(name)
        run_cmd = job.get("run", "echo 'no command specified'")
        job_defs[slug] = {
            "docker": [{"image": "cimg/base:current"}],
            "steps": [
                "checkout",
                {"run": {"name": name, "command": _yaml_block_scalar(run_cmd)}},
            ],
        }
        workflow_jobs.append(slug)
    doc = {
        "version": 2.1,
        "jobs": job_defs,
        "workflows": {"custom": {"jobs": workflow_jobs}},
    }
    path = os.path.join(".circleci", "config-custom.yml")
    _write_yaml_file(path, doc, header="# Auto-generated by batten regenerate -- do not edit manually.")


def _write_yaml_file(path, doc, header=""):
    """Write a dict to a YAML file, using PyYAML if available, else JSON-ish fallback."""
    with open(path, "w") as f:
        if header:
            f.write(header + "\n")
        if yaml:
            yaml.dump(doc, f, default_flow_style=False, sort_keys=False, allow_unicode=True)
        else:
            import json
            f.write(json.dumps(doc, indent=2))
    print(f"  Wrote {path}")


def cmd_regenerate(args):
    data = load_batten()

    existing = [f for f in MANAGED_FILES if os.path.exists(f)]
    if existing and sys.stdin.isatty():
        print(f"  Warning: {len(existing)} existing files will be overwritten:")
        for f in existing:
            print(f"    {f}")
        resp = input("  Continue? [y/N] ")
        if resp.lower() != 'y':
            print("  Aborted.")
            sys.exit(0)

    flags = build_copier_flags(data)
    cmd = ["copier", "update", "--trust", "--force"] + flags
    print(f"  Running: copier update ...\n")
    rc = subprocess.run(cmd).returncode
    if rc != 0:
        print("\nCopier exited with errors.", file=sys.stderr)
        sys.exit(rc)
    ci_jobs = _get(data, "ci_extra_jobs", [])
    ci_platform = _get(data, "ci.platform", "github")
    if ci_jobs:
        _write_ci_custom(ci_jobs, ci_platform=ci_platform)
    _ok("Regeneration complete.")


def cmd_diff(_args):
    data = load_batten()
    flags = build_copier_flags(data)
    cmd = ["copier", "update", "--trust", "--force", "--pretend"] + flags
    sys.exit(subprocess.run(cmd).returncode)


# -- Commands: Install ---------------------------------------------------------

def _install_methodology(data):
    """Install external methodology via git submodule if configured."""
    source = _get(data, "methodology.source")
    if not source:
        return
    path = _get(data, "methodology.path", ".methodology")
    version = _get(data, "methodology.version")
    init_script = _get(data, "methodology.init")

    real_path = os.path.realpath(path)
    repo_root = os.path.realpath(".")
    if not real_path.startswith(repo_root):
        print(f"Error: methodology.path '{path}' resolves outside repository.", file=sys.stderr)
        sys.exit(1)

    if os.path.isdir(path):
        print(f"  Methodology already installed at {path}")
        if version:
            print(f"  Pinning to {version}")
            _run(["git", "fetch", "--tags"], check=False, cwd=path)
            _run(["git", "checkout", version], check=False, cwd=path)
    else:
        print(f"  Installing methodology from {source}")
        r = _run_quiet(["git", "config", "--file", ".gitmodules", "--get",
                         f"submodule.{path}.url"])
        if r.returncode == 0:
            print(f"  Submodule already registered, initializing...")
            _run(["git", "submodule", "update", "--init", path])
        else:
            _run(["git", "submodule", "add", "--", source, path])
        if version:
            print(f"  Pinning to {version}")
            _run(["git", "checkout", version], check=False, cwd=path)

    if init_script:
        full_init = os.path.join(path, init_script)
        if os.path.isfile(full_init):
            real_init = os.path.realpath(full_init)
            if not real_init.startswith(os.path.realpath(path)):
                print(f"Error: init script '{init_script}' resolves outside methodology path.", file=sys.stderr)
                sys.exit(1)
            print(f"  Will run methodology init: {full_init}")
            if sys.stdin.isatty():
                resp = input("  Continue? [y/N] ")
                if resp.lower() != 'y':
                    print("  Skipped init script.")
                    return
            _run(["bash", full_init])
        else:
            print(f"  Warning: init script not found at {full_init}")


def cmd_init(_args):
    """Interactive Batten setup using Copier."""
    if os.path.exists(BATTEN_FILE):
        _err(f"{BATTEN_FILE} already exists. Use ./batten regenerate to update.")
        sys.exit(1)
    if not _has_cmd("copier"):
        _err("copier is required. Install with: pip install 'copier>=9,<11'")
        sys.exit(1)
    _info("Initializing new Batten project...")
    _info("Answer the prompts to configure your stack.\n")
    _run(["copier", "copy", "--trust", "gh:ehowardtillit/batten", "."])
    if os.path.exists(BATTEN_FILE):
        _ok("batten.yml created. Run ./batten install to complete setup.")
    else:
        _err("Initialization failed -- batten.yml was not created.")
        sys.exit(1)


def cmd_install(_args):
    data = load_batten()
    _info(f"Install v{_version()}")
    print("=" * 40)

    existing = [f for f in MANAGED_FILES if os.path.exists(f)]
    if existing and sys.stdin.isatty():
        print(f"  Warning: {len(existing)} existing files will be overwritten:")
        for f in existing:
            print(f"    {f}")
        resp = input("  Continue? [y/N] ")
        if resp.lower() != 'y':
            print("  Aborted.")
            sys.exit(0)

    # 1. Bootstrap: language toolchains
    print("\n[1/5] Bootstrapping language toolchains...")
    if os.path.isfile("bootstrap.sh"):
        _run(["bash", "bootstrap.sh"])
    else:
        print("  No bootstrap.sh found, skipping.")

    # 2. Methodology: install external methodology if configured
    print("\n[2/5] Methodology setup...")
    mtype = _get(data, "methodology.type", "batten")
    source = _get(data, "methodology.source")
    if mtype == "custom" and source:
        _install_methodology(data)
    elif mtype == "custom":
        print("  Custom methodology selected but no source configured in batten.yml.")
        print("  Add methodology.source to batten.yml if you want auto-install,")
        print("  or install your methodology manually.")
    else:
        print("  Using Batten's built-in methodology (S/A/B/C tiers).")

    # 3. Pre-commit hooks
    print("\n[3/5] Installing pre-commit hooks...")
    if _has_cmd("pre-commit"):
        _run(["pre-commit", "install"], check=False)
    else:
        print("  pre-commit not found, skipping. Install with: pip install pre-commit")

    # 4. Stack tools
    print("\n[4/5] Checking stack tools...")
    if _get(data, "stack.engineering_memory.mempalace"):
        if _has_cmd("mempalace"):
            print("  MemPalace: installed")
            slug = _project_slug(data)
            print(f"  Mining repository into MemPalace wing '{slug}'...")
            _run(["mempalace", "mine", ".", "--wing", slug], check=False)
        else:
            print("  MemPalace: not installed (pip install mempalace)")
    if _get(data, "stack.workflow.gstack"):
        if _has_cmd("gstack") or os.path.isdir(".gstack"):
            print("  gstack: available")
        else:
            print("  gstack: not found (see https://github.com/garrytan/gstack)")
    rt = _get(data, "stack.enforcement.runtime", "none")
    if rt != "none":
        print(f"  Runtime enforcement: {rt} (verify manually)")
    mg = _get(data, "stack.enforcement.merge_gate", "none")
    if mg != "none":
        print(f"  Merge gate: {mg} (verify CI config)")
    if _get(data, "stack.security.codeguard"):
        print("  CodeGuard: enabled (verify semgrep rules)")

    # 5. Context files
    print("\n[5/5] Generating context files...")
    _run_context_refresh(data)

    # Summary
    print("\n" + "=" * 40)
    _ok("Install complete. Run ./batten status to verify.")


def cmd_bootstrap(_args):
    if not os.path.isfile("bootstrap.sh"):
        print("Error: bootstrap.sh not found.", file=sys.stderr)
        sys.exit(1)
    _run(["bash", "bootstrap.sh"])


