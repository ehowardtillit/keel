def _build_find_name_expr(langs):
    """Build a find -name expression covering all enabled languages."""
    globs = []
    glob_map = {
        "python": ["*.py"],
        "typescript": ["*.ts", "*.tsx"],
        "go": ["*.go"],
        "rust": ["*.rs"],
        "php": ["*.php"],
        "elixir": ["*.ex", "*.exs"],
        "java": ["*.java", "*.kt"],
        "csharp": ["*.cs"],
        "ruby": ["*.rb"],
    }
    for lang in langs:
        globs.extend(glob_map.get(lang, []))
    if not globs:
        globs = ["*.py"]
    parts = []
    for i, g in enumerate(globs):
        if i > 0:
            parts.append("-o")
        parts.append("-name")
        parts.append(f'"{g}"')
    return " ".join(parts)


def _run_context_refresh(data):
    os.makedirs(".github/context", exist_ok=True)
    langs = _enabled_langs(data) or ["python"]
    name_expr = _build_find_name_expr(langs)

    with open(".github/context/MODULE_MAP.md", "w") as f:
        f.write("# Module Map\n\n")
        f.write("<!-- Auto-generated by batten context refresh -- do not edit manually -->\n\n")
    _run(
        'for dir in $(find . -maxdepth 2 \\( ' + name_expr + ' \\) 2>/dev/null '
        "| sed 's|/[^/]*$||' | sort -u "
        "| grep -vE '\\.venv|venv|__pycache__|\\.git|node_modules|target' | head -30); do "
        'count=$(find "$dir" -maxdepth 1 \\( ' + name_expr + ' \\) | wc -l); '
        'echo "| \\`$dir\\` | $count files |" >> .github/context/MODULE_MAP.md; '
        "done",
        check=False,
    )

    with open(".github/context/CHANGELOG_RECENT.md", "w") as f:
        f.write("# Recent Changes\n\n")
        f.write("<!-- Auto-generated by batten context refresh -- do not edit manually -->\n\n")
    _run("git log --oneline -50 >> .github/context/CHANGELOG_RECENT.md 2>/dev/null || true")

    with open(".github/context/CHANGELOG_RECENT.md", "a") as f:
        f.write("\n## Recent Plans\n\n")
    _run(
        r"""for f in $(ls -t docs/plans/*.md 2>/dev/null | grep -v template | grep -v README | head -5); do
            title=$(head -1 "$f" | sed 's/^# //')
            echo "- [\`$f\`] $title" >> .github/context/CHANGELOG_RECENT.md
        done""",
        check=False,
    )

    with open(".github/context/CHANGELOG_RECENT.md", "a") as f:
        f.write("\n## Recent Implementations\n\n")
    _run(
        r"""for f in $(ls -t docs/implementations/*.md 2>/dev/null | grep -v template | grep -v README | head -5); do
            title=$(head -1 "$f" | sed 's/^# //')
            echo "- [\`$f\`] $title" >> .github/context/CHANGELOG_RECENT.md
        done""",
        check=False,
    )
    _ok("Context files refreshed.")


def _run_context_live(data):
    slug = _project_slug(data)
    os.makedirs(".github/context", exist_ok=True)

    arch_path = ".github/context/ARCHITECTURE.md"
    if not os.path.isfile(arch_path):
        with open(arch_path, "w") as f:
            f.write("# Architecture\n\n")
            f.write("<!-- Auto-generated by batten context live -- do not edit manually -->\n\n")

    with open(arch_path, "a") as f:
        f.write("\n## MemPalace Context\n")

    _run(["mempalace", "search", "architecture overview", "--wing", slug],
         check=False)
    _run(["mempalace", "kg_timeline"], check=False)

    _run_context_refresh(data)
    print("Context files refreshed from MemPalace.")


